# Copia este archivo como ".env" y completa tus datos reales.
# NUNCA subas el archivo ".env" a un repositorio público.

# Tu API Key de Resend (la obtienes en https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Correo remitente verificado en Resend (debe ser de un dominio que verifiques en Resend)
FROM_EMAIL=Only Love <verificacion@tu-dominio.com>

# Puerto donde correrá el backend
PORT=3000

# Origen permitido para CORS (la URL donde corre tu frontend)
FRONTEND_ORIGIN=http://localhost:5500
